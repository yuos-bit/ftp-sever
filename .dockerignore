# ============================================================
# .dockerignore — 提高 Docker 构建效率
# 更新日期: 2026-07-09
# 忽略不需要进入构建上下文的文件和目录
# ============================================================

# Git
.git
.gitignore
.gitattributes

# IDE 和编辑器
.idea
.vscode
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
*.pyc

# Docker 文件（构建时不需要）
.dockerignore

# 日志
logs/

# 本地挂载目录（构建时不需要）
home/

# 文档和许可证（构建时不需要）
README.md
LICENSE

# 图片资源
*.png